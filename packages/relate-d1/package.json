{
  "name": "@nokto-labs/relate-d1",
  "version": "0.1.0",
  "description": "Cloudflare D1 adapter for @nokto-labs/relate CRM SDK.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nokto-labs/crm",
    "directory": "packages/relate-d1"
  },
  "homepage": "https://github.com/nokto-labs/crm#readme",
