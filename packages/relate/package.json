{
  "name": "@nokto-labs/relate",
  "version": "0.1.0",
  "description": "A CRM SDK for developers. Define your schema in code, get typed clients instantly.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nokto-labs/crm",
    "directory": "packages/relate"
  },
  "homepage": "https://github.com/nokto-labs/crm#readme",
  "bugs": "https://github.com/nokto-labs/crm/issues",
  "keywords": ["crm", "sdk", "typescript", "schema", "api", "relationships", "events"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  }
}
