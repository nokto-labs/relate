{
  "name": "@nokto-labs/relate",
  "version": "0.7.0",
  "description": "Define your domain in TypeScript. Get typed records, relationships, activity tracking, dynamic lists, and a full REST API.",
  "type": "module",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nokto-labs/relate",
    "directory": "packages/relate"
  },
  "homepage": "https://github.com/nokto-labs/relate#readme",
  "bugs": "https://github.com/nokto-labs/relate/issues",
  "keywords": ["relate", "sdk", "typescript", "schema", "api", "relationships", "events", "domain-modeling", "cloudflare", "d1"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.5.0"
  }
}
